<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PelisySeries" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_bg</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="android:statusBarColor">@color/brand_bg</item>
        <item name="android:navigationBarColor">@color/brand_bg</item>
        <item name="android:windowBackground">@color/brand_bg</item>
    </style>

    <style name="Theme.PelisySeries.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.PelisySeries</item>
    </style>
</resources>